# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/charitap

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# JWT Configuration (if using JWT auth)
JWT_SECRET=your_jwt_secret_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Rate Limiting Configuration
RATE_LIMIT_WINDOW=15  # in minutes
RATE_LIMIT_MAX=100    # max requests per window

# Logging Configuration
LOG_LEVEL=info  # error, warn, info, debug

# Cache Configuration
CACHE_TTL=300  # in seconds (5 minutes)

# Geo-Blocking Configuration (comma-separated country codes)
GEO_BLOCK_COUNTRIES=CN,RU,KP  # China, Russia, North Korea

# Monitoring Configuration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK/URL

# External Monitoring (Optional)
# DATADOG_API_KEY=your_datadog_api_key
# NEWRELIC_LICENSE_KEY=your_newrelic_license_key
# SENTRY_DSN=your_sentry_dsn

# Security Configuration
SESSION_SECRET=your_session_secret_here

# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:3000
