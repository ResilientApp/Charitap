{
    "manifest_version": 3,
    "name": "Round‑Up Charity",
    "version": "1.0",
    "description": "Round up your online payments and donate the spare change.",
    "permissions": [
      "storage",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["contentScript.js"]
      }
    ],
    "web_accessible_resources": [
    {
      "resources": ["assets/charity.png"],
      "matches": ["<all_urls>"]
    }
  ]
  }
  