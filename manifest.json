{
    "manifest_version": 3,
    "name": "Round‑Up Charity",
    "version": "1.0",
    "description": "Round up your online payments and donate the spare change.",
    "permissions": [
      "storage",
      "scripting",
      "cookies"
    ],
    "externally_connectable": {
      "matches": ["http://localhost:3000/*", "<all_urls>"]
    },
    "host_permissions": [
      "http://localhost:3000/*",
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["http://localhost:3000/*", "<all_urls>"],
        "js": ["contentScript.js"]
      }
    ],
    "web_accessible_resources": [
    {
      "resources": ["assets/charity.png", "patterns.json", "widget.css"],
      "matches": ["http://localhost:3000/*", "<all_urls>"]
    }
  ]
  }

  