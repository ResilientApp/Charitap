{
    "manifest_version": 3,
    "name": "Charitap",
    "version": "1.0",
    "description": "Transform spare change into impact. Charitap automatically rounds up your online purchases and donates the difference to verified charities.",
    "icons": {
      "16": "public/images/extension/icon16.png",
      "48": "public/images/extension/icon48.png",
      "128": "public/images/extension/icon128.png"
    },
    "permissions": [
      "storage",
      "scripting",
      "cookies"
    ],
    "externally_connectable": {
      "matches": ["http://localhost:3000/*", "<all_urls>"]
    },
    "host_permissions": [
      "http://localhost:3000/*",
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "exclude_matches": ["http://localhost:3000/*", "https://localhost:3000/*", "http://127.0.0.1:3000/*", "https://127.0.0.1:3000/*"],
        "js": ["contentScript.js"]
      }
    ],
    "web_accessible_resources": [
    {
      "resources": ["public/images/icons/charity.png", "patterns.json", "src/styles/extension.css", "public/images/extension/icon16.png", "public/images/extension/icon48.png", "public/images/extension/icon128.png"],
      "matches": ["http://localhost:3000/*", "<all_urls>"]
    }
  ]
  }

  